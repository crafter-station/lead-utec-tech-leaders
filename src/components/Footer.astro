---
import LeadMark from "./LeadMark.astro";
import CSMark from "./CSMark.astro";
---
<footer class="footer">
  <p class="f-cta">¡Únete para dar el salto a la industria tecnológica!</p>

  <div class="f-divider" aria-hidden="true"></div>

  <div class="f-row">
    <div class="f-brand">
      <div class="f-lockup" aria-label="LEAD UTEC × Crafter Station">
        <span class="f-mark f-mark--lead"><LeadMark /></span>
        <span class="f-x" aria-hidden="true">×</span>
        <span class="f-mark f-mark--cs"><CSMark variant="filled" /></span>
      </div>
      <div class="f-brand-meta">
        <span class="f-brand-name">LEAD <span class="f-brand-sep">|</span> UTEC</span>
        <span class="f-brand-sub">× Crafter Station · Universidad de Ingeniería y Tecnología</span>
      </div>
    </div>

    <a href="#intro" class="f-top">
      <span class="f-top-label">Volver arriba</span>
      <svg class="f-top-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 19 V5 M6 11 L12 5 L18 11"/>
      </svg>
    </a>
  </div>
</footer>

<style>
  .footer {
    margin-top: clamp(48px, 6vw, 80px);
    padding: clamp(36px, 4vw, 56px);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-card);
    background:
      radial-gradient(60% 80% at 50% 0%, rgba(255, 193, 7, 0.06), transparent 70%),
      var(--bg);
    display: flex;
    flex-direction: column;
    gap: clamp(28px, 3vw, 40px);
  }

  .f-cta {
    font-family: "Geist", sans-serif;
    font-size: clamp(22px, 2.6vw, 32px);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--ink);
    max-width: 720px;
  }

  .f-divider {
    height: 1px;
    background: var(--hairline);
    width: 100%;
  }

  .f-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }

  .f-brand {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
  }
  .f-lockup {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 7px 12px;
    border: 1px solid var(--hairline-strong);
    border-radius: 999px;
    background: var(--surface);
    flex-shrink: 0;
  }
  .f-mark {
    display: inline-grid;
    place-items: center;
    flex-shrink: 0;
  }
  .f-mark--lead { width: 32px; height: 32px; }
  .f-mark--cs {
    width: 24px;
    height: 24px;
    filter: drop-shadow(0 4px 8px rgba(255, 193, 7, 0.25));
  }
  .f-mark :global(svg),
  .f-mark :global(img) {
    width: 100%;
    height: 100%;
    display: block;
  }
  .f-x {
    font-family: "Geist", sans-serif;
    font-weight: 300;
    font-size: 14px;
    color: var(--ink-mute);
    letter-spacing: -0.04em;
    line-height: 1;
  }
  .f-brand-meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .f-brand-name {
    font-family: "Geist", sans-serif;
    font-weight: 700;
    font-size: 16px;
    letter-spacing: -0.005em;
    color: var(--ink);
    line-height: 1.2;
  }
  .f-brand-sep {
    color: var(--forged-gold);
    font-weight: 500;
    margin: 0 4px;
  }
  .f-brand-sub {
    font-family: "Geist Mono", monospace;
    font-size: 11px;
    color: var(--ink-mute);
    letter-spacing: 0.04em;
    line-height: 1.3;
  }

  a.f-top,
  a.f-top:link,
  a.f-top:visited,
  a.f-top:hover,
  a.f-top:active {
    text-decoration: none;
  }
  .f-top {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 9px 14px;
    border-radius: 999px;
    border: 1px solid var(--hairline);
    font-family: "Geist Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-mute);
    background: transparent;
    transition: color 200ms ease, border-color 200ms ease, background 200ms ease;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .f-top:hover {
    color: var(--ink);
    border-color: var(--ink-mute);
    background: color-mix(in srgb, var(--ink) 4%, transparent);
  }
  .f-top-icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  @media (max-width: 520px) {
    .f-row {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
