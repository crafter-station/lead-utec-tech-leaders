---
import LeadMark from "./LeadMark.astro";
import CSMark from "./CSMark.astro";
---
<section id="intro" class="cover">
  <div class="c-orbs" aria-hidden="true">
    <span class="c-orb c-orb--1"></span>
    <span class="c-orb c-orb--2"></span>
    <span class="c-orb c-orb--3"></span>
    <span class="c-orb c-orb--4"></span>
  </div>
  <div class="cover-grid" aria-hidden="true"></div>

  <span class="c-tick c-tick--tl" aria-hidden="true"></span>
  <span class="c-tick c-tick--tr" aria-hidden="true"></span>
  <span class="c-tick c-tick--bl" aria-hidden="true"></span>
  <span class="c-tick c-tick--br" aria-hidden="true"></span>

  <div class="c-content">
    <div class="c-eyebrow-row">
      <div class="c-lockup" aria-label="LEAD UTEC × Crafter Station">
        <span class="c-mark c-mark--lead"><LeadMark /></span>
        <span class="c-x" aria-hidden="true">×</span>
        <span class="c-mark c-mark--cs"><CSMark variant="filled" /></span>
      </div>
    </div>

    <div class="c-center">
      <h1 class="c-title">
        <span class="c-title-line">Tech Leaders</span>
        <span class="c-title-line c-title-x-line" aria-hidden="true">×</span>
        <span class="c-title-line c-title-line--gold">Crafter Station<span class="dot">.</span></span>
      </h1>

      <p class="c-sub">
        Transforma el conocimiento académico en experiencia real de la industria.
        <br />
        Conecta con los líderes que están marcando el ritmo del mundo laboral.
      </p>

      <div class="c-cta-row">
        <a href="#fechas" class="cta cta--primary">
          <span>5 y 6 de junio</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12 H19 M13 6 L19 12 L13 18"/>
          </svg>
        </a>
        <a href="#speakers" class="cta cta--ghost">
          <span>Conoce a los speakers</span>
        </a>
      </div>
    </div>

  </div>
</section>

<style>
  .cover {
    position: relative;
    min-height: 86vh;
    max-height: 960px;
    margin-bottom: clamp(40px, 5vw, 64px);
    overflow: hidden;
    border-radius: var(--radius-card);
    background:
      radial-gradient(60% 50% at 20% 0%, rgba(255, 193, 7, 0.10), transparent 70%),
      radial-gradient(50% 40% at 90% 100%, rgba(231, 236, 242, 0.07), transparent 70%),
      var(--bg);
    border: 1px solid var(--hairline);
  }

  .cover-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right,  rgba(255, 255, 255, 0.04) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255, 255, 255, 0.04) 1px, transparent 1px);
    background-size: calc(100% / 12) calc(100% / 8);
    pointer-events: none;
  }

  .c-orbs {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .c-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(40px);
    mix-blend-mode: screen;
    will-change: transform;
  }
  /* Orb 1 — top-left corner */
  .c-orb--1 {
    width: 320px;
    height: 320px;
    top: -80px;
    left: -80px;
    background: radial-gradient(circle, rgba(255, 193, 7, 0.95), rgba(255, 193, 7, 0.32) 40%, transparent 72%);
    animation: orb-drift-1 12s ease-in-out infinite;
    opacity: 0.85;
  }
  /* Orb 2 — top-right corner */
  .c-orb--2 {
    width: 380px;
    height: 380px;
    top: -100px;
    right: -100px;
    background: radial-gradient(circle, rgba(255, 212, 53, 0.90), rgba(255, 193, 7, 0.26) 40%, transparent 72%);
    animation: orb-drift-2 14s ease-in-out infinite -4s;
    opacity: 0.8;
  }
  /* Orb 3 — bottom-left corner */
  .c-orb--3 {
    width: 260px;
    height: 260px;
    bottom: -60px;
    left: -60px;
    background: radial-gradient(circle, rgba(231, 236, 242, 0.75), rgba(231, 236, 242, 0.22) 45%, transparent 72%);
    animation: orb-drift-3 13s ease-in-out infinite -8s;
    opacity: 0.7;
  }
  /* Orb 4 — bottom-right corner */
  .c-orb--4 {
    width: 340px;
    height: 340px;
    bottom: -90px;
    right: -90px;
    background: radial-gradient(circle, rgba(221, 166, 7, 0.90), rgba(198, 139, 5, 0.26) 45%, transparent 72%);
    animation: orb-drift-4 15s ease-in-out infinite -11s;
    opacity: 0.8;
  }

  /* All four converge near the center, then return.
     Different scales/durations keep them out of sync. */
  @keyframes orb-drift-1 {
    /* TL → center */
    0%, 100% { transform: translate(0, 0) scale(1); }
    50%      { transform: translate(720px, 380px) scale(1.35); }
  }
  @keyframes orb-drift-2 {
    /* TR → center */
    0%, 100% { transform: translate(0, 0) scale(1); }
    50%      { transform: translate(-760px, 380px) scale(1.3); }
  }
  @keyframes orb-drift-3 {
    /* BL → center */
    0%, 100% { transform: translate(0, 0) scale(1); }
    50%      { transform: translate(740px, -360px) scale(1.45); }
  }
  @keyframes orb-drift-4 {
    /* BR → center */
    0%, 100% { transform: translate(0, 0) scale(1); }
    50%      { transform: translate(-780px, -400px) scale(1.3); }
  }

  @media (prefers-reduced-motion: reduce) {
    .c-orb { animation: none; }
  }

  .c-tick {
    position: absolute;
    width: 16px;
    height: 16px;
    pointer-events: none;
  }
  .c-tick::before, .c-tick::after {
    content: "";
    position: absolute;
    background: var(--ink);
    opacity: 0.6;
  }
  .c-tick::before { width: 16px; height: 1px; top: 8px; }
  .c-tick::after  { width: 1px;  height: 16px; left: 8px; }
  .c-tick--tl { top: 28px;    left: 28px;  }
  .c-tick--tr { top: 28px;    right: 28px; }
  .c-tick--bl { bottom: 28px; left: 28px;  }
  .c-tick--br { bottom: 28px; right: 28px; }

  .c-content {
    position: absolute;
    inset: 0;
    padding: clamp(56px, 7vw, 88px);
    display: grid;
    grid-template-rows: auto 1fr;
    gap: 24px;
    z-index: 1;
  }

  .c-eyebrow-row {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    justify-self: center;
    flex-wrap: wrap;
  }
  .c-lockup {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 7px 12px;
    border: 1px solid var(--hairline-strong);
    border-radius: 999px;
    background: color-mix(in srgb, var(--surface) 70%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .c-mark {
    display: inline-grid;
    place-items: center;
    flex-shrink: 0;
  }
  .c-mark--lead { width: 32px; height: 32px; }
  .c-mark--cs {
    width: 24px;
    height: 24px;
    filter: drop-shadow(0 4px 8px rgba(255, 193, 7, 0.25));
  }
  .c-x {
    font-family: "Geist", sans-serif;
    font-weight: 300;
    font-size: 16px;
    color: var(--ink-mute);
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .c-center {
    align-self: center;
    justify-self: center;
    display: grid;
    justify-items: center;
    gap: clamp(20px, 2.5vw, 32px);
    max-width: 880px;
    text-align: center;
  }

  .c-title {
    display: grid;
    gap: 4px;
    font-family: "Geist", sans-serif;
    font-weight: 700;
    font-size: clamp(38px, 7vw, 104px);
    letter-spacing: -0.045em;
    line-height: 0.95;
    color: var(--ink);
  }
  .c-title-line { display: block; }
  .c-title-line--gold {
    background: linear-gradient(180deg, #FFD435 0%, #FFC107 55%, #C68B05 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .c-title-x-line {
    font-size: 0.5em;
    font-weight: 300;
    letter-spacing: 0;
    color: var(--ink-mute);
    line-height: 1;
    margin: 0.1em 0;
  }
  .c-title .dot { color: var(--forged-gold); -webkit-text-fill-color: var(--forged-gold); }

  .c-sub {
    font-family: "Geist", sans-serif;
    font-size: clamp(15px, 1.5vw, 19px);
    line-height: 1.55;
    color: var(--ink-mute);
    max-width: 640px;
  }

  .c-cta-row {
    display: inline-flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 4px;
  }
  .cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 20px;
    border-radius: 999px;
    font-family: "Geist Mono", monospace;
    font-size: 11.5px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    transition: transform 200ms var(--ease-spring), background 200ms ease, border-color 200ms ease, color 200ms ease;
  }
  .cta svg { width: 14px; height: 14px; }
  .cta--primary { background: var(--forged-gold); color: #1a1300; }
  .cta--primary:hover { transform: translateY(-2px); background: var(--gold-light); }
  .cta--ghost {
    border: 1px solid var(--hairline-strong);
    color: var(--ink);
    background: transparent;
  }
  .cta--ghost:hover {
    background: color-mix(in srgb, var(--ink) 6%, transparent);
    border-color: var(--ink-mute);
  }

  @media (max-width: 520px) {
    .c-content { padding: 40px 22px; }
    .c-tick { display: none; }
  }
</style>
