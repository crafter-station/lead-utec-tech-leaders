---
import { SPEAKERS } from "../lib/speakers";
---
<div class="speakers-row">
  {SPEAKERS.map((s) => (
    <a href={`#talk-${s.id}`} class="sp card-surface">
      <div class="sp-head">
        <span class="sp-num">{s.num}</span>
        <span class={`sp-area sp-area--${s.area.toLowerCase().replace(' ', '-')}`}>{s.area}</span>
      </div>

      <div class="sp-portrait" aria-hidden="true">
        {s.photo ? (
          <img class="sp-photo" src={s.photo} alt="" loading="lazy" decoding="async" />
        ) : (
          <span class="sp-initials">{s.initials}</span>
        )}
        <span class="sp-grid"></span>
      </div>

      <div class="sp-meta">
        <h3 class="sp-name">{s.name}</h3>
        <span class="sp-role">{s.role}</span>
      </div>

      <div class="sp-talk">
        <span class="sp-talk-label">Career talk</span>
        <p class="sp-talk-title">{s.talkTitle}</p>
      </div>

      <span class="sp-arrow" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M7 17 L17 7 M9 7 H17 V15"/>
        </svg>
      </span>
    </a>
  ))}
</div>

<style>
  .speakers-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .sp {
    position: relative;
    padding: 22px 22px 24px;
    display: flex;
    flex-direction: column;
    gap: 18px;
    text-decoration: none;
    color: inherit;
    transition: border-color 220ms var(--ease-out), transform 220ms var(--ease-out);
    overflow: hidden;
  }
  .sp::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: var(--radius-card);
    pointer-events: none;
    box-shadow: 0 0 0 0 color-mix(in srgb, var(--forged-gold) 0%, transparent);
    transition: box-shadow 220ms var(--ease-out);
  }
  .sp:hover {
    border-color: color-mix(in srgb, var(--forged-gold) 40%, var(--hairline));
    transform: translateY(-4px);
  }
  .sp:hover::after {
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--forged-gold) 40%, transparent);
  }

  .sp-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .sp-num {
    font-family: "Geist Mono", monospace;
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: 0.18em;
    color: var(--forged-gold);
    padding: 3px 7px;
    background: color-mix(in srgb, var(--forged-gold) 12%, transparent);
    border-radius: 4px;
  }
  .sp-area {
    font-family: "Geist Mono", monospace;
    font-size: 9.5px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-mute);
    padding: 3px 8px;
    border: 1px solid var(--hairline);
    border-radius: 999px;
  }

  .sp-portrait {
    position: relative;
    aspect-ratio: 1 / 1;
    border-radius: var(--radius-sm);
    background:
      radial-gradient(ellipse at 30% 20%, rgba(255, 193, 7, 0.10), transparent 65%),
      linear-gradient(180deg, #1A1A1A 0%, #0F0F0F 100%);
    display: grid;
    place-items: center;
    overflow: hidden;
    border: 1px solid var(--hairline);
  }
  .sp-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right,  rgba(255, 255, 255, 0.05) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
    background-size: 24px 24px;
    pointer-events: none;
    mix-blend-mode: overlay;
    opacity: 0.6;
  }
  .sp-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 25%;
    filter: saturate(0.95) contrast(1.02);
    transition: transform 320ms var(--ease-out), filter 320ms var(--ease-out);
  }
  .sp:hover .sp-photo {
    transform: scale(1.03);
    filter: saturate(1.05) contrast(1.05);
  }
  .sp-initials {
    position: relative;
    font-family: "Geist", sans-serif;
    font-weight: 700;
    font-size: clamp(48px, 5vw, 76px);
    letter-spacing: -0.04em;
    color: var(--ink);
    background: linear-gradient(180deg, #FFD435 0%, #FFC107 55%, #C68B05 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    filter: drop-shadow(0 8px 18px rgba(255, 193, 7, 0.20));
  }

  .sp-meta { display: flex; flex-direction: column; gap: 4px; }
  .sp-name {
    font-family: "Geist", sans-serif;
    font-size: 19px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--ink);
    line-height: 1.15;
  }
  .sp-role {
    font-family: "Geist Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--ink-mute);
  }

  .sp-talk {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-top: 14px;
    border-top: 1px solid var(--hairline);
  }
  .sp-talk-label {
    font-family: "Geist Mono", monospace;
    font-size: 9.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--forged-gold);
  }
  .sp-talk-title {
    font-family: "Geist", sans-serif;
    font-size: 14px;
    line-height: 1.4;
    color: var(--ink);
    letter-spacing: -0.005em;
  }

  .sp-arrow {
    position: absolute;
    top: 22px;
    right: 22px;
    width: 28px;
    height: 28px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    color: var(--ink-mute);
    opacity: 0;
    transform: translate(-4px, 4px);
    transition: opacity 220ms var(--ease-out), transform 220ms var(--ease-out), background 220ms ease, color 220ms ease;
  }
  .sp:hover .sp-arrow {
    opacity: 1;
    transform: translate(0, 0);
    background: var(--forged-gold);
    color: #1a1300;
  }
  .sp-arrow svg { width: 14px; height: 14px; }

  @media (max-width: 1100px) {
    .speakers-row { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 520px) {
    .speakers-row { grid-template-columns: 1fr; }
  }
</style>
