---
const LUMA_EVENT_ID = "xs1ra3xm";
const LUMA_URL = `https://luma.com/${LUMA_EVENT_ID}`;
const LUMA_EMBED = `https://lu.ma/embed/event/${LUMA_EVENT_ID}/simple`;
---
<div class="reg-wrap">
  <div class="reg-frame">
    <iframe
      class="reg-iframe"
      src={LUMA_EMBED}
      title="Registro al evento Tech Leaders × Crafter Station — Luma"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      allow="fullscreen"
      width="100%"
      height="500"
    ></iframe>
  </div>

  <a class="reg-fallback" href={LUMA_URL} target="_blank" rel="noopener">
    <span>Abrir en Luma</span>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M7 17 L17 7 M9 7 H17 V15"/>
    </svg>
  </a>
</div>

<style>
  .reg-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    width: 100%;
  }
  .reg-frame {
    width: 100%;
    max-width: 720px;
    border-radius: var(--radius-card);
    overflow: hidden;
    border: 1px solid var(--hairline);
    background: var(--surface);
    box-shadow: var(--shadow-card);
  }
  .reg-iframe {
    display: block;
    width: 100%;
    min-height: 500px;
    border: 0;
    color-scheme: light;
  }

  .reg-fallback {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    border-radius: 999px;
    border: 1px solid var(--hairline);
    font-family: "Geist Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--ink-mute);
    background: transparent;
    transition: color 200ms ease, border-color 200ms ease, background 200ms ease;
  }
  .reg-fallback:hover {
    color: var(--ink);
    border-color: var(--ink-mute);
    background: color-mix(in srgb, var(--ink) 4%, transparent);
  }
  .reg-fallback svg {
    width: 12px;
    height: 12px;
    flex-shrink: 0;
  }
</style>
