---
interface Props {
  class?: string;
  ariaLabel?: string;
}
const { class: className = "", ariaLabel = "LEAD UTEC" } = Astro.props;
---
<img
  class={`lead-mark ${className}`.trim()}
  src="/lead_utec.png"
  alt={ariaLabel}
  loading="eager"
  decoding="async"
  width="1080"
  height="1080"
  style="display:block; width:100%; height:100%; object-fit:contain;"
/>
